#################################################################################                                                                           ## # SLATE: System for Local Area Traffic Estimation                             ##                                                                             ## by David Levinson                                                           # #                                                                             # # date of last update: 02/13/91                                               # #                                                                             # # usage: slate SSSS R MM > & fooSSSS &                                        # #                                                                             # # where: SSSS = 4 digit scenario number                                       # #           R = 1 letter run identifier                                       # #                                                                             # ##                                                                           ## ############################################################################################################################################################### set $emme2 release version###############################################################################set emme2=/users/emme2/rel5.2/etc/emme2################################################################################ set model parameters###############################################################################set scenario=$1set run=$2set scendum=1set scendem=2set iterate=1set previter=0set stepsize=1set limit=15set outerloop=1set callimit=1set turnset="yes"set assignment="yes"        set autocal="no"     ################################################################################ determine output plots (yes/no)###############################################################################set pltdff=no set pltcap=noset pltffs=noset pltspd=noset pltcfr=noset pltclv=noset plttmv=noset pltvcr=yesset pltlan=no################################################################################ set default directories###############################################################################set returnTo = $cwdset macros="/mnt/macros/slate"set bin="/mnt/Mtools/Ttools/bin"set source="/mnt/Mtools/Ttools/source"set configure="$returnTo/configure"set countsfile="$configure/d241.count2"set turncounts="noturns"set speedsfile="nospeeds"set delay="$configure/delay"set nodename="$configure/nodename.in"set turnlanes="$configure/lanes.in2"set turnpro="$configure/d231.turnpro"set szconfig="$configure/szconfig"set gravity="$configure/rep.travwk90" set levity="$configure/rep.travnwk90" set intcap="$configure/intcap"set prepdem="no" set rf="$returnTo/rf$scenario$run"################################################################################# Do some directory manipulations###############################################################################if ( -e $rf) then  rm -fr $rf  rmdir $rfendifmkdir $rfrm errorstouch errors################################################################################# Prepare module parameters###############################################################################$emme2 clear batch -m "$macros/t.scenario $scenario"$emme2 clear batch -m "$macros/t.switches"################################################################################ ASSUMES VDF ALREADY NEWVDF ##################################################################################################################################  $emme2 clear batch -m "$macros/t.scenario $scendem"#   $emme2 clear 241 batch -m "$macros/t.startcap"#  $emme2 clear batch -m "$macros/t.scenario $scenario"#   $emme2 clear 241 batch -m "$macros/t.startcap"################################################################################################################################################################ Initialize Turn Penalties ###############################################################################if ($turnset == "yes" ) then   awk -f $source/makedeftl.a $turnlanes > $returnTo/d231.in   $bin/idelay8 $nodename $turnlanes $returnTo/d231.in $intcap   if ($status != 0) then       banner "FAILED"       banner "IDELAY"       exit   endif   echo "t turns init" > $returnTo/d231.in   sort -n +1 -2 +2 -3 +3 -4 $turnpro $returnTo/d231.out >> $returnTo/d231.in   awk -f $source/nozero.a $returnTo/d231.in > $returnTo/d231.in2   mv $returnTo/d231.in2 $returnTo/d231.in   cp $returnTo/d231.in $rf/d231.in   if ( $autocal == "network" ) then      $emme2 clear batch -m "$macros/t.scenario $scendem"      $emme2 clear 231 batch -m "$macros/t.clear231"      $emme2 clear batch -m "$macros/t.scenario $scenario"   endif   $emme2 clear 231 batch -m "$macros/t.clear231"   mv reports $rf/rep.turnpen################################################################################## Create Dummy Scenario###############################################################################   $emme2 clear 122 batch -m "$macros/t.createdummy $scenario"################################################################################## for Dummy Scenario Initialize Turn Penalties###############################################################################   $emme2 clear batch -m "$macros/t.scenario $scendum"     $emme2 clear 231 batch -m "$macros/t.clear231"   $emme2 clear batch -m "$macros/t.scenario $scenario"   mv $returnTo/d231.out $rf/d231.outendif################################################################################# TRANSPOSE MATRICES###############################################################################if ( $prepdem == "yes" ) then$emme2 clear 312 batch -m "$macros/t.transpose"################################################################################# ACCESS TO TRANSIT###############################################################################$emme2 clear 214 batch -m "$macros/t.listcents"awk -f $source/cent2matrix.a reportscat d311.xcoord d311.ycoord > d311.in$emme2 clear 311 batch$emme2 clear 321 batch -m "$macros/t.trandist"rm d311.xcoord d311.ycoord d311.in################################################################################# TRIP GENERATION###############################################################################$emme2 clear 321 batch -m "$macros/t.LATRtrip3pm"################################################################################# PREP GRAVITY###############################################################################echo "t matrices" > d311.inecho "d matrix=mf01" >> d311.inecho  "a matrix=mf01 ftable 0.00001 Regional WK Traversal Matrix"  >> d311.inawk '{ if ( NF == 3 && $1/1 > 0 ) {print "   gn"$1"   gn"$2,$3 }}' $gravity >> d311.inawk '{ if ( NF==3 && $1 ~ /[0-9]/ ) {otrips[$1]+=$3; dtrips[$2]+=$3 } } END {for (i in otrips) { print i,otrips[i],dtrips[i]}}' $gravity > externs1sort -n +0 -1 -o externs1 externs1echo "d matrix=mo11" >> d311.inecho "d matrix=md11" >> d311.inecho "a matrix=mo11 name=oexter default=0.0001 descr=external p & a" >> d311.inawk '{if ($1 > 50 && $1 < 99 ) {printf ("   %6d  all: %8.2f\n",$1,$2)}}' externs1 >> d311.inecho "a matrix=md11 name=dexter default=0.0001 descr=external p & a" >> d311.inawk '{if ($1 > 50 && $1 < 99 ) {printf ("    all: %4d %8.2f\n",$1,$3)}}' externs1 >> d311.in$emme2 clear 311 batchmv externs1 $rf################################################################################# PREP LEVITY###############################################################################echo "t matrices" > d311.inecho "d matrix=mf02" >> d311.inecho  "a matrix=mf02 ftable 0.00001 Regional NW Traversal Matrix"  >> d311.inawk '{ if ( NF == 3 && $1/1 > 0 ) {print "   gn"$1"   gn"$2,$3 }}' $levity >> d311.inawk '{ if ( NF==3 && $1 ~ /[0-9]/ ) {otrips[$1]+=$3; dtrips[$2]+=$3 } } END {for (i in otrips) { print i,otrips[i],dtrips[i]}}' $levity > externs2sort -n +0 -1 -o externs2 externs2echo "d matrix=mo12" >> d311.inecho "d matrix=md12" >> d311.inecho "a matrix=mo12 name=oexter default=0.0001 descr=external p & a" >> d311.inawk '{if ($1 > 50 && $1 < 99 ) {printf ("   %6d  all: %8.2f\n",$1,$2)}}' externs2 >> d311.inecho "a matrix=md12 name=dexter default=0.0001 descr=external p & a" >> d311.inawk '{if ($1 > 50 && $1 < 99 ) {printf ("    all: %4d %8.2f\n",$1,$3)}}' externs2 >> d311.in$emme2 clear 311 batchmv externs2 $rf################################################################################# NORMALIZATION : Make sure Os match Ds###############################################################################$emme2 clear 321 batch -m "$macros/t.normalize3"################################################################################# DESTINATION CHOICE: Distribute Trips using consistent TRAVEL 2 pattern###############################################################################$emme2 clear 322 batch -m "$macros/t.distribute3" ################################################################################# SUMTABLE : Make sure Os match Ds###############################################################################$emme2 clear 321 batch -m "$macros/t.sumtable4"$emme2 clear 321 batch -m "$macros/t.kfactor4"################################################################################# Output Reports###############################################################################$emme2 clear 314 batch -m "$macros/t.punchPA"mv $returnTo/reports $rf/rep.PAsubzoneawk -f $source/aggregatorPA.a $rf/rep.PAsubzone $szconfig > $rf/rep.PAzoneendif################################################################################# Output Demand################################################################################$emme2 clear 314 batch -m "$macros/t.punchmat mf04"#mv $returnTo/batchout $returnTo/d311.mf04#pack $returnTo/d311.mf04################################################################################# ROUTE CHOICE: STATIC USER EQUILIBRIUM ASSIGNMENT###############################################################################while ( $outerloop <= $callimit )while ( $iterate <= $limit )  $emme2 clear batch -m "$macros/t.scenario $scenario"  if ( $iterate == "1" ) then       if ($assignment != "calibrate") then             $emme2 clear 511 batch -m "$macros/t.assignment4 $previter"       else if ($assignment == "calibrate") then            if ($autocal == "network") then             $emme2 clear 511 batch -m "$macros/t.capadj1s $previter"            else if ($autocal == "matrix") then             $emme2 clear 511 batch -m "$macros/t.capadj1x $previter"            endif       endif     $emme2 clear 521 batch     if ( $status != 0 ) then       banner "FAILED"       banner "ASSIGNMENT"       echo   "iteration $iterate"       exit     endif     cat $returnTo/reports >> $rf/rep.521dd  else if ( $iterate > "1" ) then############################ Intersection Delay Model##########################    $emme2 clear 611 batch -m "$macros/t.611int"    if ($status != 0) then      banner "FAILED"      banner "611REPORT"      echo   "nodes: iteration $iterate"      exit    endif   awk '{if ($1~/[0-9]/ && NF>6) {printf ("%6d %6d %6d %6d\n",$1,$2,$3,$(NF-2))}}' $returnTo/reports > $rf/turnvols.in   $bin/idelay8 $nodename $turnlanes $rf/turnvols.in $intcap   if ($status != 0) then      banner "FAILED"      banner "IDELAY"      echo   "iteration $iterate"      exit   endif############################ Intersection Equilibration Algorithm##########################   echo "t turns" > d231.x   sort -n +1 -2 +2 -3 +3 -4 $returnTo/d231.out $turnpro >> $returnTo/d231.x   if ( $iterate < 3 )  then     awk '{ if ( NF != 8 ) {print $0}; if (NF == 8) {print "m "$2,$3,$4,$5,$6,$7,$8}}' $returnTo/d231.x >  $returnTo/d231.in   endif   if ( $iterate > 2 )  then     paste $returnTo/d231.x $rf/d231.in > $returnTo/d231.temp     awk -f $source/averager2.a iterate=$iterate $returnTo/d231.temp > $returnTo/d231.in   endif   mv $returnTo/d231.out $rf   awk -f $source/nozero.a $returnTo/d231.in > $returnTo/d231.in2   mv $returnTo/d231.in2 $returnTo/d231.in   cp $returnTo/d231.in $rf/d231.in   $emme2 clear batch -m "$macros/t.scenario 1"        $emme2 clear 231 batch -m "$macros/t.clear231"        $emme2 clear 511 batch -m "$macros/t.511dummy"        $emme2 clear 111 batch -m "$macros/t.copyfile41 $scenario"#       $emme2 clear 111 batch -m "$macros/t.copyfile42 $scenario"   $emme2 clear batch -m "$macros/t.scenario $scenario"   mv $returnTo/turnvols.out $rf/rep.turnvols   mv $returnTo/critical.out $rf/rep.critical   mv $returnTo/interdesc.out $rf/rep.interdesc   mv $returnTo/sigstat.out $rf/rep.sigstat   rm $returnTo/d231.x $returnTo/d231.in $returnTo/d231.temp############################ Link Model##########################    $emme2 clear 511 batch -m "$macros/t.511more $previter"    $emme2 clear 521 batch    if ($status != 0) then       banner "FAILED"       banner "ASSIGNMENT"       echo   "iteration $iterate"       exit    endif    cat $returnTo/reports >> $rf/rep.521dd  endif###################################### UPDATE INNER LOOP####################################@ previter = $iterate @ iterate = $iterate + $stepsizeend###################################### system performance measure####################################$emme2 clear 321 batch -m "$macros/t.sumtime4"mv reports $rf/rep.sumtime$outerloop################################################################################# CALIBRATION ROUTINES:## d411 is prepped## ul1 = observed volume## ul2 = capacity###############################################################################if ( $autocal != "no" ) then################################################################################# CALIBRATE MODEL: ADJUST DEMAND ###############################################################################   $emme2 clear 122 batch -m "$macros/t.createscen $scenario $scendem"  $emme2 clear batch -m "$macros/t.scenario $scendem"   $emme2 clear 241 batch -m "$macros/m.zeroudata ul3"   cp $countsfile d241.in   $emme2 clear 241 batch -m "$macros/t.countin"#  cp $speedsfile d241.in#  $emme2 clear 241 batch -m "$macros/t.speedin"   $emme2 clear 241 batch -m "$macros/m.demadj2s"   if ( $autocal == "network" ) then      $emme2 clear 241 batch -m "$macros/t.copycap $scenario"      $emme2 clear 241 batch -m "$macros/t.copyspd $scenario"   endif   set flag = "0"   $emme2 clear 511 batch -m "$macros/m.demadj3s $flag"   while ($flag <= $limit)      $emme2 clear 521 batch       cat reports >> $rf/rep.521dem      $emme2 clear 611 batch -m "$macros/t.611int"      if ($status != 0) then        banner "FAILED"        banner "611REPORT"        echo   "nodes: flag iteration $flag"        echo   "nodes: outerloop $outerloop"        exit      endif      awk -f $source/prepidel.a $returnTo/reports > $rf/turnvols.in      $bin/idelay8 $nodename $turnlanes $rf/turnvols.in  $intcap      if ($status != 0) then         banner "FAILED"         banner "IDELAY"         echo   "idelay: flag iteration $flag"         echo   "idelay: outerloop $outerloop"         exit      endif############################ Intersection Equilibration Algorithm##########################      echo "t turns" > d231.x      sort -n +1 -2 +2 -3 +3 -4 $returnTo/d231.out $turnpro >> $returnTo/d231.x      paste $returnTo/d231.x $rf/d231.in > $returnTo/d231.temp      awk -f $source/averager2.a iterate=$iterate $returnTo/d231.temp > $returnTo/d231.in      mv $returnTo/d231.out $rf      cp $returnTo/d231.in $rf/d231.in      $emme2 clear batch -m "$macros/t.scenario $scendum"        $emme2 clear 231 batch -m "$macros/t.clear231"        $emme2 clear 511 batch -m "$macros/t.511dummy"        $emme2 clear 111 batch -m "$macros/t.copyfile42 $scendem"      $emme2 clear batch -m "$macros/t.scenario $scendem"      @ flag = $flag + $stepsize    $emme2 clear 511 batch -m "$macros/t.511more $flag"   end   $emme2 clear 321 batch -m "$macros/m.demadj4s"   $emme2 clear 241 batch -m "$macros/m.demadj5s"   if ( $autocal == "network" ) then     $emme2 clear 321 batch -m "$macros/m.demadj6s"   else if ( $autocal == "matrix" ) then     $emme2 clear 321 batch -m "$macros/m.demadj6x"   endif################################################################################# CALIBRATE MODEL: ADJUST CAPACITY###############################################################################if ( $autocal == "network" ) then   @ iterate = $iterate + $stepsize   @ previter = $iterate    $emme2 clear batch -m "$macros/t.scenario $scenario"    $emme2 clear 511 batch -m "$macros/t.511more $previter"    $emme2 clear 521 batch     cat reports >> $rf/rep.521dd    $emme2 clear 611 batch -m "$macros/t.reptlink"    mv $returnTo/reports $rf/rep.611cap    $emme2 clear 214 batch -m "$macros/t.listlink"    mv $returnTo/reports $rf/rep.214cap    $source/rearrange $rf/rep.611cap $rf/rep.214cap $rf/listlink$outerloop    $bin/scalib $rf/listlink$outerloop $returnTo/d241.in    $emme2 clear 241 batch -m "$macros/t.lcalibin"    cp $returnTo/d241.in $rf/lcalib$outerloop    $emme2 clear 611 batch -m "$macros/t.611int"       if ($status != 0) then         banner "FAILED"         banner "611REPORT"         echo   "nodes: iteration $iterate"         echo   "       outerloop $outerloop"         exit       endifendifendif########################### increment outerloop, reset iterate##########################  $emme2 clear batch -m "$macros/t.scenario $scenario"  @ outerloop = $outerloop + $stepsize  set iterate = "1"  set previter = "0"end################################################################################# FINAL PLOTS##################################################################################################################### Difference Simulated - Observed Volumes Plot####################################if ($pltdff == "yes") then   cp $countsfile d241.in   $emme2 clear 241 batch -m "$macros/t.difference"   $emme2 clear 213 batch -m "$macros/t.plotdiff"   mv $returnTo/plots  $rf/plt.dff$1endif######################################## Plot Freeflow Speeds#####################################if ($pltffs == "yes") then   $emme2 clear 241 batch -m "$macros/t.colorffs"   $emme2 clear 213 batch -m "$macros/t.plotffs"   mv $returnTo/plots  $rf/plt.ffs$1endif######################################## Plot Capacities#####################################if ($pltcap == "yes") then   $emme2 clear 241 batch -m "$macros/t.colorcap"   $emme2 clear 213 batch -m "$macros/t.plotcap"   mv $returnTo/plots  $rf/plt.cap$1endif######################################## Speed Plot#####################################if ($pltspd == "yes") then   $emme2 clear 241 batch -m "$macros/t.calcspeed"   $emme2 clear 612 batch -m "$macros/t.plotspeed"   mv $returnTo/plots $rf/plt.spd$1endif######################################## Congested Freeflow Ratio Plot#####################################if ($pltcfr == "yes") then   $emme2 clear 241 batch -m "$macros/t.calccfr"   $emme2 clear 213 batch -m "$macros/t.plotcfr"   mv $returnTo/plots $rf/plt.cfr$1endif######################################## CLV Plot on network#####################################if ($pltclv == "yes") then   cp $rf/rep.critical $returnTo/d241.in   $emme2 clear 241 batch -m "$macros/t.critical"   $emme2 clear 213 batch -m "$macros/t.plotcrit"   mv $returnTo/plots $rf/plt.clv$1endif######################################## Turning Movement Volumes#####################################if ($plttmv == "yes") then   $emme2 clear 614 batch -m "$macros/t.plottmv"   mv $returnTo/plots $rf/plt.tmv$1endif######################################## Color Coded Lanes Plot#####################################if ($pltlan == "yes") then   $emme2 clear 241 batch -m "$macros/t.colorlanes"   $emme2 clear 213 batch -m "$macros/t.plotlanes"   mv $returnTo/plots $rf/plt.lan$1endif###################################### LOS Volume Capacity Ratio Plot with Policy Capacities####################################if ($pltvcr == "yes") then   $emme2 clear 241 batch -m "$macros/t.polcap.bcbd"   $emme2 clear 612 batch -m "$macros/t.modpar612"   $emme2 clear 612 batch -m "$macros/t.612vcrplot"   mv $returnTo/plots $rf/plt.vcr$1endif##################################### Reporter with Policy Capacities####################################$emme2 clear 611 batch -m "$macros/t.611punch"awk -f $source/611fix.a reports > $rf/rep.611$bin/nbreporter $delay $rf/rep.611  #$bin/screenline $countsfile $rf/rep.611 $rf/out.stolink mv statistics $rf################################################################################# EXIT###############################################################################exit