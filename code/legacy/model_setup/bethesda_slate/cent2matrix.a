BEGIN {print "t matrices" > "d311.xcoord"print "d matrix=mo27" > "d311.xcoord"print "d matrix=mo28" > "d311.ycoord"print "a matrix=mo27 xcoord 0 x coordinate of centroid (mdstplft)" > "d311.xcoord"print "a matrix=mo28 ycoord 0 y coordinate of centroid (mdstplft)" > "d311.ycoord"}{     cent=$1      xcoord=$2      ycoord=$3      if (cent/1 > 0 && cent/1 < 6000) {      print "   "cent"  all: "xcoord > "d311.xcoord"      print "   "cent"  all: "ycoord > "d311.ycoord"}}END {}