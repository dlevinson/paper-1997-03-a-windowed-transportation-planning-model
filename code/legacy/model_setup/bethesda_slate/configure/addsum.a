BEGIN {omax=0       dmax=0}{ ozone=$1  dzone=$2  if (ozone > omax ) {omax=ozone}  if (dzone > dmax ) {dmax=dzone}  flow=$3  flowx[ozone]+= flow  flowy[dzone]+= flow }END { print "origin            flow"      for (ozone=1;ozone<=omax;ozone++) { if (flowx[ozone] > 0) {printf ("%6d %15.4f\n", ozone, flowx[ozone]) }}      print "destination       flow"      for (dzone=1;dzone<=dmax;dzone++) { if (flowy[dzone] > 0) { printf ("%6d %15.4f\n", dzone, flowy[dzone]) }}      }