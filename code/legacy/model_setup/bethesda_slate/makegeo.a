BEGIN { for (x=1;x<99999;x++) {yes[x]=0}}# makegeo.a - awkscript to make geometrics for grid road system# DML 7.13.92FILENAME=="node4.in" {  inode=$1  yes[inode]=inode }FILENAME=="nodes" {  adm=$1  inode=$2  xc=$3  yc=$4  xcn[inode]=xc  ycn[inode]=yc }FILENAME=="links" {  adm=$1  inode=$2  jnode=$3  if ( yes[inode]/1 > 0 && jnode > 10000 ) { noden[inode]++			    jnoden[inode*100+noden[inode]]=jnode}}END {   for ( inode in yes ) { if ( yes[inode]/1 > 0 ) {      xcmax=0     ycmax=0     xcmin=999999     ycmin=999999     nnode=0     snode=0     enode=0     wnode=0     for (x=1;x<=noden[inode];x++) { jnode=jnoden[inode*100+x]				     xc=xcn[jnode]				     yc=ycn[jnode]				     if (xc > xcmax) {nnode=jnode						      xcmax=xc}				     if (xc < xcmin) {snode=jnode						      xcmin=xc}				     if (yc > ycmax) {enode=jnode						      ycmax=yc}				     if (yc < ycmin) {wnode=jnode						      ycmin=yc}                                    }       printf ("%6d %6d %6d %6d %6d 001000 001000 001000 001000  makegeo\n",inode,nnode,snode,enode,wnode)}} }