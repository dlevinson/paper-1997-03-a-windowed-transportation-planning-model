BEGIN { }{  taxid=substr($0,1,8)/1   luse1=substr($0,10,3)/1   gfa=substr($0,14,11)/1   oldtz=substr($0,26,3)/1   landarea=substr($0,30,10)/1   ftacres=substr($0,41,1)   if (ftacres=="A") {landarea=landarea*435.6}   zoning  =substr($0,43,10)   streetad=substr($0,54,30)   block   =substr($0,84,3)   lot     =substr($0,87,3)   parcel  =substr($0,92,3)   redevtyp=substr($0,96,1)   mappage =substr($0,98,4)   xcoord =substr($0,103,6)/1   ycoord =substr($0,111,6)/1   units  =substr($0,117,4)/1 if ( units/1 == "0" ) { units=1 } if ( xcoord/1 > 0 && ycoord/1 > 0  && luse1/1 > 110  && gfa/1 !=0)  {	 printf ("a %12d %12d %12d %12d %12d %12d\n",taxid,xcoord,ycoord,gfa,landarea,luse1)  }}END {}