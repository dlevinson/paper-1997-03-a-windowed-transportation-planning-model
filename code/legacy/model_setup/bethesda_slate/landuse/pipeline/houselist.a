#a   419831    777897.00    421667.00    408288.00  34412400.00       124.00     5410    777164.00    421178.00          .10      2705.00        37.00# commlist.a # usage: awk -f commlist.a d211.commout > d311.commout# DML 7.7.92BEGIN { }{ adm=$1  taxid=$2  xc=$3  yc=$4  land=$5  units=$6  luse1=$7  tzone=$8  xc2=$9  yc2=$10  uz1=$11  uz2=$12  uz3=$13 if (luse1/1 == 111  )  { luse3=19 } if (luse1/1 == 114  )  { luse3=20 } if (luse1/1 == 119  )  { luse3=22 }     print "m matrix=mo"luse3" name=LU"luse1/1" default=incr descr=Land Use Cod"luse1/1     printf ("   %5d all: %10d\n",tzone,units) }END {}