BEGIN {temp=0}FILENAME == "correcte.int" {  at=$1/1  fr=$2/1  to=$3/1  vol=$4/1   temp= temp+1  atx[temp]=at  frx[temp]=fr  tox[temp]=to  volx[temp]=vol }FILENAME == "turnvol.9630a" {  at=$1/1  fr=$2/1  to=$3/1  sim=$4/1  for (i=1;i<=temp;i++) {    if ( atx[i]==at && tox[i]==to && frx[i]==fr ) {  obs=volx[i]   print at,fr,to,obs+sim    i=temp+1 }}}END {}