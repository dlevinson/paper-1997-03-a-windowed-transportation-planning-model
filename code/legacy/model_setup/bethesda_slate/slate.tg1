#################################################################################                                                                           ## # SLATE: System for Local Area Traffic Estimation                             ##                                                                             ## by David Levinson                                                           # #                                                                             # # date of last update: 02/13/91                                               # #                                                                             # # usage: slate SSSS R MM > & fooSSSS &                                        # #                                                                             # # where: SSSS = 4 digit scenario number                                       # #           R = 1 letter run identifier                                       # #                                                                             # ##                                                                           ## ############################################################################################################################################################### set $emme2 release version###############################################################################set emme2=/users/emme2/rel5.2/etc/emme2################################################################################ set model parameters###############################################################################set scenario=$1set run=$2set scendum=1set scendem=2set iterate=1set previter=0set stepsize=1set limit=15set outerloop=1set callimit=1set turnset="yes"set assignment="yes"        set autocal="no"     ################################################################################ determine output plots (yes/no)###############################################################################set pltdff=no set pltcap=noset pltffs=noset pltspd=noset pltcfr=noset pltclv=noset plttmv=noset pltvcr=yesset pltlan=no################################################################################ set default directories###############################################################################set returnTo = $cwdset macros="/mnt/macros/slate"set bin="/mnt/Mtools/Ttools/bin"set source="/mnt/Mtools/Ttools/source"set configure="$returnTo/configure"set countsfile="$configure/d241.count2"set turncounts="noturns"set speedsfile="nospeeds"set delay="$configure/delay"set nodename="$configure/nodename.in"set turnlanes="$configure/lanes.in2"set turnpro="$configure/d231.turnpro"set szconfig="$configure/szconfig"set gravity="$configure/rep.travwk97c"set levity="$configure/rep.travnwk97c"set intcap="$configure/intcap"set prepdem="no" set rf="$returnTo/rf$scenario$run"################################################################################# Do some directory manipulations###############################################################################if ( -e $rf) then  rm -fr $rf  rmdir $rfendifmkdir $rfrm errorstouch errors################################################################################# Prepare module parameters###############################################################################$emme2 clear batch -m "$macros/t.scenario $scenario"$emme2 clear batch -m "$macros/t.switches"################################################################################ ASSUMES VDF ALREADY NEWVDF ##################################################################################################################################  $emme2 clear batch -m "$macros/t.scenario $scendem"#   $emme2 clear 241 batch -m "$macros/t.startcap"#  $emme2 clear batch -m "$macros/t.scenario $scenario"#   $emme2 clear 241 batch -m "$macros/t.startcap"################################################################################################################################################################ TRANSPOSE MATRICES###############################################################################$emme2 clear 312 batch -m "$macros/t.transpose"################################################################################# ACCESS TO TRANSIT###############################################################################$emme2 clear 214 batch -m "$macros/t.listcents"awk -f $source/cent2matrix.a reportscat d311.xcoord d311.ycoord > d311.in$emme2 clear 311 batch$emme2 clear 321 batch -m "$macros/t.trandist"#rm d311.xcoord d311.ycoord d311.in################################################################################# TRIP GENERATION###############################################################################$emme2 clear 321 batch -m "$macros/t.LATRtrip4pm"exit