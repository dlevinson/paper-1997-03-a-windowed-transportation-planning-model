 ~/ ##############################
 ~/ ORIGINS
 ~/ ##############################
 1         /matrix calculations
 y            /save
 mo01
 y        /change header
 TRIPSO
 Trips Originating in Zone
 y            /initialize
 0         /default
 (((mo06/1000)*1.38 + (mo07/1000)*1.70 - mo08*7+ (mo09/1000)*1.70 + mo10*115) * 
 (1-(0.50)*(mo30.le.1000)))*0.13
  
                 /constraint matrix
 n              /no submatrix
 1         /matrix calculations
 y            /save
 mo01
 n        /change header
 mo01+0.25*((mo11/1000)*12.36+(mo13/1000)*7.43+(mo15/1000)*12.36
 -0.05*mo16+0.2*(200-mo16)+
 (mo17/1000)*7.43-0.05*mo18+0.2*(200-(mo17/1000)))*0.53 
  
                 /constraint matrix
 n              /no submatrix
 1         /matrix calculations
 y            /save
 mo01
 n        /change header
 mo01+((mo19*0.95)*(mo19.le.75)+(mo19*0.62+25)*(mo19.gt.75))*0.73
 +((mo20*0.48)*(mo20.le.100)+(mo20*0.53-5)*(mo20.gt.100))*0.76
 +((mo21*0.44)*(mo21.le.75)+(mo21*0.40+3)*(mo21.gt.75))*0.76
 +((mo22*0.40)*(mo22.le.100)+(mo22*0.29+11)*(mo22.gt.100))*0.75

                 /constraint matrix
 n              /no submatrix
 ~/ ##############################
 ~/ DESTINATIONS
 ~/ ##############################
 1         /matrix calculations
 y            /save
 md01
 y        /change header
 TRIPSD
 Trips Destined For Zone
 y            /initialize
 0         /default
 (((md06/1000)*1.38 + (md07/1000)*1.70 - md08*8+ (md09/1000)*1.70 + md10*115) * 
 (1-(0.50)*(md04.le.1000)))*0.87
  
                 /constraint matrix
 n              /no submatrix
 1         /matrix calculations
 y            /save
 md01
 n        /change header
 md01+0.25*((md11/1000)*12.36+(md13/1000)*7.43+(md15/1000)*12.36-0.05*md16
 +0.2*(200-md16)+(md17/1000)*7.43-0.05*md18+0.2*(200-(md17/1000)))*0.53 
  
                 /constraint matrix
 n              /no submatrix
 1         /matrix calculations
 y            /save
 md01
 n        /change header
 md01+((md19*0.95)*(md19.le.75)+(md19*0.62+25)*(md19.gt.75))*0.27
 +((md20*0.48)*(md20.le.100)+(md20*0.53-5)*(md20.gt.100))*0.24
 +((md21*0.44)*(md21.le.75)+(md21*0.40+3)*(md21.gt.75))*0.24
 +((md22*0.40)*(md22.le.100)+(md22*0.29+11)*(md22.gt.100))*0.25

                 /constraint matrix
 n              /no submatrix
 q
