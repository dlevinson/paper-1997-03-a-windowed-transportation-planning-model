 +((md20*0.83)*(md20.le.100)+(md20*0.48+35)*(md20.gt.100))*0.59
 +((md21*0.48)*(md21.le.75)+(md21*0.47+1)*(md21.gt.75))*0.59
 +((md22*0.46)*(md22.le.100)+(md22*0.34+12)*(md22.gt.100))*0.62
  
                 /constraint matrix
