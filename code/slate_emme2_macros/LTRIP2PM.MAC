 ~/ ##############################
 ~/ ORIGINS
 ~/ ##############################
 1         /matrix calculations
 y            /save
 mo01
 y        /change header
 TRIPSO
 Trips Originating in Zone
 y            /initialize
 0         /default
 ~/ mo19 = single family
 ~/ mo20 = townhouse
 ~/ mo21 = garden apartment
 ~/ mo22 = high rise
 ~/     121 - rooming and boarding houses
 ~/     122 - membership lodgings (ITE 591)
 ~/     123 - dormitory 
 ~/     124 - retirement homes and orphanages (ITE 250)
 ~/     125 - religous quarters 
 ~/     126 - nursing homes (ITE 620)
 ~/     127 - hospitals (ITE 610)
 ~/     140 - mobile homes (ITE 240)
 ~/     151 - hotels (ITE 310)
 ((mo19*1.11)*(mo19.le.75)+(mo19*0.82+21)*(mo19.gt.75))*0.38 
 +((mo20*0.83)*(mo20.le.100)+(mo20*0.48+35)*(mo20.gt.100))*0.41
 +((mo21*0.48)*(mo21.le.75)+(mo21*0.47+1)*(mo21.gt.75))*0.41
 +((mo22*0.46)*(mo22.le.100)+(mo22*0.34+12)*(mo22.gt.100))*0.38
  
                 /constraint matrix
 n              /no submatrix
 1         /matrix calculations
 y            /save
 mo01
 n        /change header
 ~/ mo52    502 - subregional shopping (ITE 820) MCPD
 ~/ mo53    503 - convenience center with grocery or drug store (ITE 820) MCPD
 ~/ mo56    541 - Groceries Retail (ITE 850)
 mo01+
 (((mo52+mo53+mo56)/1000)*(9.96)*((mo52+mo53+mo56).lt.50000)+
 (618+(((mo52+mo53+mo56)-50000)/1000)*(7.43))*((mo52+mo53+mo56).ge.50000))*
 (0.53)
  
                 /constraint matrix
 n              /no submatrix
 1         /matrix calculations
 y            /save
 mo01
 n        /change header
 ~/ mo91    504 - highway commercial (not covered elsewhere) (ITE 820) MCPD
 ~/ mo55    531 - Department Store (ITE 820)
 ~/ mo62    599 - Other Retail Trade and Service -- Consumer Oriented
 mo01+
 (((0.95)*((mo91+mo55+mo62)/1000)*(9.96)+(0.2)*(200-((mo91+mo55+mo62)/1000))
 *((mo91+mo55+mo62).lt.50000))+
 (618+(0.95)*(((mo91+mo55+mo62)-50000)/1000)*(7.43)+
 (0.2)*(200-((mo91+mo55+mo62)/1000))))*((mo91+mo55+mo62).ge.50000)
 *(0.53)
  
                 /constraint matrix
 n              /no submatrix
 1         /matrix calculations
 y            /save
 mo01
 n        /change header
 ~/ mo92     501 - Regional Shopping Center (ITE 820) MCPD
 mo01+(3.0)*(mo92/1000)*(0.53)
  
                 /constraint matrix
 n
 1         /matrix calculations
 y            /save
 mo01
 n        /change header
 ~/ mo54    519 - Wholesale (non-warehouse) (ITE 860)
 ~/ mo93    521 - Lumber and Other Building Materials (ITE 816)
 ~/ mo57    551 - Car Sales (ITE 841)
 ~/ mo58    553 - Gas Station (ITE 844)
 ~/ mo59    559 - Other Automotive Retail  (ITE 840)
 mo01+ 
 (0.52)*(mo54/1000)*(0.50)+
 (4.87)*(mo93/1000)*(0.54)+
 (2.62)*(mo57/1000)*(0.59)+
 (81.95)*(mo58/1000)*(0.50)+
 (2.87)*(mo59/1000)*(0.54)

             /constraint
 n           /submatrix
 ~/
 1         /matrix calculations
 y            /save
 mo01
 n
 ~/ mo60    580 - Fast Food (ITE 833) - MCPD
 ~/ mo61    581 - Eating and Drinking (ITE 831)
 ~/ mo69    637 - Warehouse Storage Facilities (ITE 150)
 ~/ mo70    639 - Mini Storage Facilities (ITE 151)
 ~/ mo71    641 - Automobile Repair (ITE 840)
 ~/ mo72    651 - Health Service Facility (ITE 630)
 ~/ mo72    653 - Health Service Facility (condo) (ITE 630)
 mo01+(34.32)*(mo60/1000)*(mo77.eq.580)*(0.45)+
 (7.66)*(mo61/1000)*(0.30)+
 (0.74)*(mo69/1000)*(0.65)+
 (0.26)*(mo70/1000)*(0.48)+
 (2.87)*(mo71/1000)*(0.54)+
 (4.08)*(mo72/1000)*(0.70)


 n        /
 1         /matrix calculations
 y            /save
 mo01
 n        /change header
 ~/ mo63    600 - Multi Tenant Office (ITE 710) MCPD
 ~/ mo64    601 - Multi Tenant Office (condo) (ITE 710) MCPD
 ~/ mo65    602 - Single Tenant Office (ITE 710) MCPD
 ~/ mo66    603 - Single Tenant Office (condo) (ITE 710) MCPD
 ~/ mo67    604 - Mixed Office and Retail (ITE 710) MCPD
 ~/ mo94    605 - Mixed Office and Retail (condo) (ITE 710) MCPD
 ~/ mo76    675 - RESERVATION
 ~/ mo07 = OFFICE OCCUPANCY
 ~/ mo30 = METRO STATION
 mo01 +(((((mo76+mo63+mo64+mo65+mo66+mo67+mo94)/1000)*2.24)
 *((mo76+mo63+mo64+mo65+mo66+mo67+mo94).lt.25000) 
 +(((mo76+mo63+mo64+mo65+mo66+mo67+mo94)/1000)*0.92 + 50)
 *((mo76+mo63+mo64+mo65+mo66+mo67+mo94).ge.25000)
 *((mo76+mo63+mo64+mo65+mo66+mo67+mo94).lt.300000)
 +(((mo76+mo63+mo64+mo65+mo66+mo67+mo94)/1000)*0.92 + 140)
 *((mo76+mo63+mo64+mo65+mo66+mo67+mo94).ge.300000))
 *(1-(0.40)*((1000-mo30)/1000)*(mo30.le.1000)) *(0.82))*mo07
                /constraint matrix
 n              /no submatrix
 1         /matrix calculations
 y            /save
 mo01
 n        /change header
 ~/ mo95    200 - ind park (ITE 130)
 ~/ mo96    201 - ind prod, multi-occ - mixed industrial (ITE 140)
 ~/ mo97    202 - ind prod, multi-occ - mixed industrial (condo) (ITE 140)
 ~/ mo45    203 - ind prod - single industrial use (fee simple)  (ITE 140)
 ~/ mo98    204 - ind prod - single industrial use (condo)  (ITE 140)
 ~/ mo46    205 - mixed industrial/commercial (ITE 110)
 ~/ mo99    206 - mixed light industrial - single occupancy (condo) (ITE 110)
 ~/ mo39    207 - research and development (ITE 760)
 ~/ mo38    671 - Government reservation (general govt)
 ~/ mo37    675 - Government reservation (military base)
 mo01
 +(((0.75)*((mo95+mo96+mo97+mo98)/1000)*(0.47)
 +(0.98)*((mo46+mo99)/1000)*(0.88)
 +(1.07)*((mo39+mo38+mo37)/1000)*(0.85))*(mo07))
 *(1-(0.40)*((1000-mo30)/1000)*(mo30.le.1000))

                 /constraint matrix
 n              /no submatrix
